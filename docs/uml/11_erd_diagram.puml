
@startuml Entity Relationship Diagram
!theme plain

entity "current_document (Runtime State)" as Document {
  * text : String
  * chunks : List<String>
  * filename : String
  --
  Notes:
  - In-memory dictionary
  - Shared across routes
  - Reset on new upload
}

entity "FAISS Index (Persistent)" as FAISSIndex {
  * dimension : Integer
  * ntotal : Integer (vector count)
  --
  Methods:
  - search(query_vector, k)
  - add(vectors)
  --
  Storage: index.faiss (binary)
}

entity "Chunk Texts (Persistent)" as Chunks {
  * chunk_texts : List<String>
  --
  Storage: chunks.pkl (pickle)
  Notes:
  - Parallel to FAISS vectors
  - Index-based retrieval
}

entity "Uploaded File (Temporary)" as UploadedFile {
  * filename : String
  * file_path : String
  * file_extension : String
  * upload_time : DateTime
  --
  Storage: data/uploads/
  Lifecycle: Temporary
}

entity "Configuration (Static)" as Config {
  * UPLOAD_FOLDER : String
  * FAISS_FOLDER : String
  * ALLOWED_EXTENSIONS : Set
  * MAX_CONTENT_LENGTH : Integer
  * MAX_TEXT_LENGTH : Integer
  * CHUNK_MAX_WORDS : Integer
  * TOP_K_CHUNKS : Integer
  * GOOGLE_API_KEY : String
  * GEMINI_MODEL : String
  * EMBEDDING_MODEL : String
  --
  Source: Environment variables
  Type: Class constants
}

entity "API Request (Transient)" as Request {
  * endpoint : String
  * method : String
  * payload : JSON/FormData
  * timestamp : DateTime
}

entity "API Response (Transient)" as Response {
  * status_code : Integer
  * body : JSON
  * error : String (optional)
}

entity "Embedding Vector" as Vector {
  * vector_id : Integer
  * embedding : Float[768]
  * chunk_index : Integer
  --
  Notes:
  - 768-dimensional vectors
  - One per chunk
  - Stored in FAISS
}

entity "Summary (Computed)" as Summary {
  * summary_text : String
  * document_filename : String
  * generation_time : DateTime
  --
  Lifecycle: Generated on-demand
  Not persisted
}

entity "Q&A Pair (Computed)" as QAPair {
  * question : String
  * answer : String
  * chunks_used : Integer
  * document_filename : String
  * timestamp : DateTime
  --
  Lifecycle: Generated per request
  Not persisted
}

' Relationships
Document ||--o{ Chunks : "contains"
Document ||--|| UploadedFile : "extracted from"

Chunks ||--|| FAISSIndex : "parallel to"
Chunks }o--|| Vector : "text for"

FAISSIndex ||--o{ Vector : "stores"

Request }o--|| Response : "receives"

Document ||--o| Summary : "generates"
Document ||--o{ QAPair : "generates"

QAPair }o--o{ Chunks : "uses top 5 from"

Config ||--o{ Document : "configures"
Config ||--o{ FAISSIndex : "configures"

note right of Document
  Central runtime state
  Shared via get_current_document()
  Cleared on new upload
end note

note right of FAISSIndex
  IndexFlatL2 (L2 distance)
  Persistent across restarts
  Fast similarity search
end note

note bottom of Chunks
  Maps FAISS indices to text
  Essential for retrieval
  Stored alongside index
end note

note right of Vector
  Generated by text-embedding-004
  768 dimensions
  Immutable once created
end note

note left of Summary
  Optional, on-demand
  Generated by Gemini 2.5 Flash
  Max 15,000 char input
end note

note left of QAPair
  Uses RAG approach
  Context from top 5 chunks
  Generated by Gemini 2.5 Flash
end note

@enduml
